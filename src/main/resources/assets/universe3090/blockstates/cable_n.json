{
  "multipart":[
    {
      "apply": { "model": "universe3090:block/cable_n" }
    },
    {
      "when": { "north": "true" },
      "apply": { "model": "universe3090:block/cable_e" }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "universe3090:block/cable_e", "y": 90 }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "universe3090:block/cable_e", "y": 180 }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "universe3090:block/cable_e", "y": 270 }
    },
    {
      "when": { "up": "true" },
      "apply": { "model": "universe3090:block/cable_e", "x": 270 }
    },
    {
      "when": { "down": "true" },
      "apply": { "model": "universe3090:block/cable_e", "x": 90 }
    }
  ]
}